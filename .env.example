# Quantum Bridge OS — environment template (copy to .env)

# Database (Docker compose sets these on the api service)
DB_HOST=localhost
DB_USER=qbridge
DB_PASSWORD=password
DB_NAME=qaas_db
DB_PORT=5432

# Auth
QBRIDGE_JWT_SECRET=change-me-in-production
QBRIDGE_JWT_EXPIRE_HOURS=24
QBRIDGE_OTP_EXPIRE_MINUTES=10
# Login OTP email — pick ONE backend (copy this file to .env and fill in)

# Option A — Brevo (easiest for Render: one API key, free tier)
# Sign up at https://www.brevo.com → SMTP & API → API Keys
QBRIDGE_BREVO_API_KEY=
QBRIDGE_BREVO_SENDER_EMAIL=your-verified-email@example.com

# Option B — Gmail SMTP (needs Google App Password)
QBRIDGE_SMTP_HOST=smtp.gmail.com
QBRIDGE_SMTP_PORT=587
QBRIDGE_SMTP_USER=your@gmail.com
QBRIDGE_SMTP_PASSWORD=your-gmail-app-password
QBRIDGE_SMTP_FROM=your@gmail.com
QBRIDGE_SMTP_TLS=1

# Only set to 1 for offline dev without email (prints code to API console)
QBRIDGE_AUTH_DEV_LOG_OTP=0

# Dev flags
QBRIDGE_SKIP_PQC_VERIFY=1
QBRIDGE_FORCE_MEMORY_DB=1
