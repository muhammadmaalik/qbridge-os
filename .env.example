# Quantum Bridge OS — environment template (copy to .env)

# Database (Docker compose sets these on the api service)
DB_HOST=localhost
DB_USER=qbridge
DB_PASSWORD=password
DB_NAME=qaas_db
DB_PORT=5432

# Auth
QBRIDGE_JWT_SECRET=change-me-in-production
QBRIDGE_JWT_EXPIRE_HOURS=24
QBRIDGE_OTP_EXPIRE_MINUTES=10
# Log OTP to console when SMTP is not configured (dev)
QBRIDGE_AUTH_DEV_LOG_OTP=1

# SMTP — required for real email OTP delivery in production
# QBRIDGE_SMTP_HOST=smtp.gmail.com
# QBRIDGE_SMTP_PORT=587
# QBRIDGE_SMTP_USER=you@gmail.com
# QBRIDGE_SMTP_PASSWORD=app-password
# QBRIDGE_SMTP_FROM=noreply@yourdomain.com
# QBRIDGE_SMTP_TLS=1

# Dev flags
QBRIDGE_SKIP_PQC_VERIFY=1
QBRIDGE_FORCE_MEMORY_DB=1
